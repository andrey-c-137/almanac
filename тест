<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Календарь с заметками</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: Arial, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }
        
        .container {
            max-width: 900px;
            margin: 0 auto;
            background: white;
            border-radius: 10px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }
        
        h1 {
            text-align: center;
            color: #333;
            margin-bottom: 30px;
        }
        
        .controls {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            flex-wrap: wrap;
            gap: 15px;
        }
        
        button {
            padding: 10px 20px;
            background: #667eea;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 14px;
            transition: background 0.3s;
        }
        
        button:hover {
            background: #764ba2;
        }
        
        .month-display {
            text-align: center;
            font-size: 24px;
            font-weight: bold;
            color: #333;
            min-width: 200px;
        }
        
        .calendar {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 10px;
            margin-bottom: 30px;
        }
        
        .day-header {
            text-align: center;
            font-weight: bold;
            color: #667eea;
            padding: 10px;
            border-bottom: 2px solid #667eea;
        }
        
        .day {
            min-height: 100px;
            border: 1px solid #ddd;
            border-radius: 5px;
            padding: 8px;
            background: #f9f9f9;
            cursor: pointer;
            transition: all 0.3s;
            position: relative;
        }
        
        .day:hover {
            background: #f0f0f0;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }
        
        .day.other-month {
            background: #e8e8e8;
            color: #999;
        }
        
        .day.today {
            background: #fff3cd;
            border: 2px solid #ffc107;
        }
        
        .day-number {
            font-weight: bold;
            color: #333;
            margin-bottom: 5px;
        }
        
        .day.other-month .day-number {
            color: #999;
        }
        
        .day-notes {
            font-size: 12px;
            color: #666;
            max-height: 60px;
            overflow: hidden;
            text-overflow: ellipsis;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
        }
        
        .day-notes.has-notes {
            color: #e74c3c;
            font-weight: bold;
        }
        
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            z-index: 1000;
            align-items: center;
            justify-content: center;
        }
        
        .modal.active {
            display: flex;
        }
        
        .modal-content {
            background: white;
            border-radius: 10px;
            padding: 30px;
            max-width: 400px;
            width: 90%;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }
        
        .modal-header {
            font-size: 20px;
            font-weight: bold;
            color: #333;
            margin-bottom: 20px;
        }
        
        textarea {
            width: 100%;
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 5px;
            font-family: Arial, sans-serif;
            resize: vertical;
            min-height: 100px;
            margin-bottom: 15px;
            font-size: 14px;
        }
        
        .modal-buttons {
            display: flex;
            gap: 10px;
            justify-content: flex-end;
        }
        
        .btn-save {
            background: #27ae60;
        }
        
        .btn-save:hover {
            background: #229954;
        }
        
        .btn-delete {
            background: #e74c3c;
        }
        
        .btn-delete:hover {
            background: #c0392b;
        }
        
        .btn-cancel {
            background: #95a5a6;
        }
        
        .btn-cancel:hover {
            background: #7f8c8d;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>📅 Календарь с заметками</h1>
        
        <div class="controls">
            <button onclick="previousMonth()">← Предыдущий</button>
            <div class="month-display" id="monthDisplay"></div>
            <button onclick="nextMonth()">Следующий →</button>
        </div>
        
        <div class="calendar" id="calendar"></div>
    </div>
    
    <div class="modal" id="noteModal">
        <div class="modal-content">
            <div class="modal-header" id="modalHeader"></div>
            <textarea id="noteText" placeholder="Введите вашу заметку..."></textarea>
            <div class="modal-buttons">
                <button class="btn-delete" onclick="deleteNote()" id="deleteBtn">Удалить</button>
                <button class="btn-cancel" onclick="closeModal()">Отмена</button>
                <button class="btn-save" onclick="saveNote()">Сохранить</button>
            </div>
        </div>
    </div>
    
    <script>
        let currentDate = new Date();
        let selectedDate = null;
        let notes = JSON.parse(localStorage.getItem('calendarNotes')) || {};
        
        function renderCalendar() {
            const year = currentDate.getFullYear();
            const month = currentDate.getMonth();
            
            // Update month display
            const monthNames = ['Январь', 'Февраль', 'Март', 'Апрель', 'Май', 'Июнь',
                             'Июль', 'Август', 'Сентябрь', 'Октябрь', 'Ноябрь', 'Декабрь'];
            document.getElementById('monthDisplay').textContent = `${monthNames[month]} ${year}`;
            
            // Get first day of month and number of days
            const firstDay = new Date(year, month, 1).getDay();
            const daysInMonth = new Date(year, month + 1, 0).getDate();
            const daysInPrevMonth = new Date(year, month, 0).getDate();
            
            const calendar = document.getElementById('calendar');
            calendar.innerHTML = '';
            
            // Day headers
            const dayHeaders = ['Пн', 'Вт', 'Ср', 'Чт', 'Пт', 'Сб', 'Вс'];
            dayHeaders.forEach(day => {
                const header = document.createElement('div');
                header.className = 'day-header';
                header.textContent = day;
                calendar.appendChild(header);
            });
            
            // Previous month days
            const startDay = firstDay === 0 ? 6 : firstDay - 1;
            for (let i = startDay - 1; i >= 0; i--) {
                const day = document.createElement('div');
                day.className = 'day other-month';
                day.innerHTML = `<div class="day-number">${daysInPrevMonth - i}</div>`;
                calendar.appendChild(day);
            }
            
            // Current month days
            const today = new Date();
            for (let date = 1; date <= daysInMonth; date++) {
                const day = document.createElement('div');
                day.className = 'day';
                
                // Check if today
                if (year === today.getFullYear() && 
                    month === today.getMonth() && 
                    date === today.getDate()) {
                    day.classList.add('today');
                }
                
                const dateKey = `${year}-${month}-${date}`;
                const hasNotes = notes[dateKey];
                
                day.innerHTML = `<div class="day-number">${date}</div>`;
                if (hasNotes) {
                    day.innerHTML += `<div class="day-notes has-notes">📝 ${hasNotes}</div>`;
                }
                
                day.onclick = () => openModal(year, month, date);
                calendar.appendChild(day);
            }
            
            // Next month days
            const totalCells = calendar.children.length - 7; // Subtract day headers
            const remainingCells = 42 - totalCells; // 6 rows * 7 days
            for (let i = 1; i <= remainingCells; i++) {
                const day = document.createElement('div');
                day.className = 'day other-month';
                day.innerHTML = `<div class="day-number">${i}</div>`;
                calendar.appendChild(day);
            }
        }
        
        function previousMonth() {
            currentDate.setMonth(currentDate.getMonth() - 1);
            renderCalendar();
        }
        
        function nextMonth() {
            currentDate.setMonth(currentDate.getMonth() + 1);
            renderCalendar();
        }
        
        function openModal(year, month, date) {
            selectedDate = { year, month, date };
            const dateKey = `${year}-${month}-${date}`;
            const noteText = notes[dateKey] || '';
            
            document.getElementById('modalHeader').textContent = 
                `${date} ${['января', 'февраля', 'марта', 'апреля', 'мая', 'июня',
                           'июля', 'августа', 'сентября', 'октября', 'ноября', 'декабря'][month]} ${year}`;
            
            document.getElementById('noteText').value = noteText;
            document.getElementById('deleteBtn').style.display = noteText ? 'block' : 'none';
            document.getElementById('noteModal').classList.add('active');
        }
        
        function closeModal() {
            document.getElementById('noteModal').classList.remove('active');
            selectedDate = null;
        }
        
        function saveNote() {
            if (!selectedDate) return;
            
            const dateKey = `${selectedDate.year}-${selectedDate.month}-${selectedDate.date}`;
            const noteText = document.getElementById('noteText').value.trim();
            
            if (noteText) {
                notes[dateKey] = noteText;
            } else {
                delete notes[dateKey];
            }
            
            localStorage.setItem('calendarNotes', JSON.stringify(notes));
            renderCalendar();
            closeModal();
        }
        
        function deleteNote() {
            if (!selectedDate) return;
            
            const dateKey = `${selectedDate.year}-${selectedDate.month}-${selectedDate.date}`;
            delete notes[dateKey];
            localStorage.setItem('calendarNotes', JSON.stringify(notes));
            renderCalendar();
            closeModal();
        }
        
        // Close modal when clicking outside
        document.getElementById('noteModal').onclick = (e) => {
            if (e.target.id === 'noteModal') closeModal();
        };
        
        // Initial render
        renderCalendar();
    </script>
</body>
</html>